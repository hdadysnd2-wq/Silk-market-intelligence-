# مفاتيح منصة سِلك — Silk platform keys.
# انسخ هذا الملف إلى .env واملأ القيم.  Copy this file to .env and fill values.
# (.env متجاهَل في git — لا يُرفع.  .env is gitignored — never committed.)

# ── مصادر البيانات · DATA SOURCES ─────────────────────────────────────────────

# UN Comtrade: اختياري. بدونه يعمل وضع المعاينة (محدود). بمفتاح مجاني يرتفع الحد
# إلى ~500 طلب/يوم. سجّل في: https://comtradedeveloper.un.org
COMTRADE_API_KEY=

# World Bank: لا يحتاج مفتاحًا إطلاقًا (مفتوح).  No key needed (open API).

# CORS: أصول الواجهة المسموح لها بنداء الـ API (مفصولة بفواصل). افتراضيًا "*".
# CORS allowed origins for an external frontend, comma-separated. Default "*".
# CORS_ORIGINS=https://your-frontend.example.com

# Google Trends (silk_trends_agent): لا مفتاح — يحتاج فقط: pip install pytrends

# Google Maps (silk_maps_agent): مجاني بحصة — مصانع/موزّعون/منافسون بالاسم وتقييماتهم.
# Free tier with quota. Real businesses + ratings by name (Places Text Search).
GOOGLE_MAPS_API_KEY=

# Web Search (silk_websearch_agent): مجاني بحصة — Serper.dev افتراضيًا (SEARCH_PROVIDER).
# Free tier. Default provider Serper.dev (Google Search). Consumer/market signals.
SEARCH_API_KEY=

# أسعار السوق المحلي (silk_localprice_agent): مدفوع — نطاق SerpApi الافتراضي.
# PAID. Real local retail prices/listings (e.g. SerpApi Google Shopping key).
LOCALPRICE_API_KEY=

# Volza (silk_volza_agent): مدفوع — مستوردون بالاسم من بيانات بوالص الشحن.
# PAID subscription. Named importers/exporters from bills of lading.
VOLZA_API_KEY=

# explee (silk_explee_agent): مدفوع — مشترون وجهات اتصال B2B (امتثال GDPR/PDPL).
# PAID account (first ~333 lookups free). B2B buyers/contacts — legitimate outreach only.
EXPLEE_API_KEY=

# D&B (silk_dnb_agent, المجموعة و/التعميق): مدفوع — التحقق من شرعية الموردين
# المكتشفين عبر رقم D-U-N-S (D&B Direct+). بلا مفتاح: لا محاولة شبكة، None موسوم.
# PAID. Supplier legal-legitimacy verification (D-U-N-S) via D&B Direct+.
DNB_API_KEY=

# الأكثر مبيعاً (silk_bestsellers_agent, المجموعة ج): مدفوع عبر Apify — مُشغّل
# مرخّص لمتاجر أمازون/نون/جوميا. السكرابينغ المباشر بكودنا ممنوع (قد يخالف ToS)؛
# نستدعي actor مرخّصاً فقط. بلا التوكن لا محاولة شبكة وتُعاد قيمة None موسومة.
# PAID via Apify — a LICENSED marketplace scraper actor. No in-code scraping of
# Amazon/Noon/Jumia (ToS risk); set BOTH the token and the actor id/name.
APIFY_API_TOKEN=
APIFY_BESTSELLERS_ACTOR=

# ── الذكاء الاصطناعي · AI LAYER (Claude judge/report, silk_ai_judge.py) ───────
# اختياري — بدونه تبقى اللجنة الحتمية فقط (silk_agents.JuryCommittee)، بلا اختلاق.
# Optional — without it, only the deterministic jury runs (no LLM, no fabrication).
ANTHROPIC_API_KEY=

# ── البنية التحتية · INFRASTRUCTURE (Railway — V3) ────────────────────────────
# Postgres (silk_db.py): تُعبّأ تلقائيًا من قالب Railway Postgres. بدونها: SQLite
# محلي (data/silk_app.db) — لا حاجة لإعداد شيء للتطوير المحلي.
# Auto-filled by Railway's Postgres template. Unset -> local SQLite fallback.
DATABASE_URL=

# Redis (silk_cache.py / silk_jobs.py / silk_ratelimit.py): تُعبّأ تلقائيًا من قالب
# Railway Redis. بدونها: كاش قرص + تنفيذ متزامن + عدّاد بالذاكرة (كل هذا يعمل
# محلياً بلا Redis، لكن الإنتاج يتطلبه فعلياً لجدولة المهام والكاش المشترك).
# Auto-filled by Railway's Redis template. Unset -> disk cache + synchronous
# jobs + in-memory rate limiting (fine for local dev, not for production).
REDIS_URL=

# رابط عام للربط داخل رسائل الدخول — used to build the magic-link URL emailed
# to users. Falls back to the incoming request's own base URL if unset.
PUBLIC_BASE_URL=

# ── المصادقة عبر البريد · MAGIC-LINK EMAIL (silk_auth.py) ─────────────────────
# بدون SMTP_HOST: رابط الدخول يُسجَّل في سجلات الخادم فقط (وضع تطوير) — غير آمن
# للإنتاج. أعِدّ SMTP حقيقياً قبل النشر الفعلي.
# Without SMTP_HOST: the login link is only logged (dev mode) — NOT safe for
# production. Configure a real SMTP provider before shipping.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── حدود الاستخدام والتكلفة · RATE LIMITS & COST (silk_ratelimit.py / api.py) ──
# حدّ التحليلات لكل مستخدم — per-user analysis caps (defaults shown).
RATE_LIMIT_PER_HOUR=20
RATE_LIMIT_PER_DAY=100
# تقدير تقريبي للتكلفة لكل تحليل، لعرضه في GET /usage — ليس فاتورة نهائية.
# Rough per-analysis cost estimate shown by GET /usage — not a final invoice.
SILK_EST_COST_PER_ANALYSIS_USD=1.5
