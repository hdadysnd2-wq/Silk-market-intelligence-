# مفاتيح منصة سِلك — Silk platform keys.
# انسخ هذا الملف إلى .env واملأ القيم.  Copy this file to .env and fill values.
# (.env متجاهَل في git — لا يُرفع.  .env is gitignored — never committed.)

# ── مصادر البيانات · DATA SOURCES ─────────────────────────────────────────────

# UN Comtrade: اختياري. بدونه يعمل وضع المعاينة (محدود). بمفتاح مجاني يرتفع الحد
# إلى ~500 طلب/يوم. سجّل في: https://comtradedeveloper.un.org
COMTRADE_API_KEY=

# World Bank: لا يحتاج مفتاحًا إطلاقًا (مفتوح).  No key needed (open API).

# ── حراسة الموجة ٠ · WAVE-0 GUARDS (اضبطها كلها في الإنتاج) ───────────────────

# مصادقة /analyze: عند ضبطه يتطلب كل طلب ترويسة X-API-Key مطابقة وإلا 401.
# غير مضبوط = وضع تطوير مفتوح. Auth for POST /analyze (401 without header).
SILK_API_KEY=

# سقف الطبقات المدفوعة اليومي: عدد تفعيلات (localprice/volza/explee/ai) المسموح
# يوميًا؛ التجاوز = 429. غير مضبوط = لا سقف (تطوير). Daily paid-layer cap (429).
# ملاحظة أمنية (M-2): عند تعذّر قراءة العدّاد (قرص/قفل/تلف) تُرفض الطبقات
# المدفوعة (fail-closed) — الرفض أأمن من تجاوز صامت للسقف.
SILK_PAID_DAILY_CAP=

# حدّ الإنفاق الدولاري اليومي (H6، تدقيق 2026-07-15): SILK_PAID_DAILY_CAP يحدّ
# *عدد* التفعيلات؛ هذا يحدّ *الدولارات* الفعلية المُقدَّرة (تشغيلة /research قد
# تكلّف ~$7 وهي تفعيلة واحدة). حجز ذرّي (BEGIN IMMEDIATE): يُحجَز التقدير قبل
# بدء /research ويُرفض البدء بـ429 حين (المُنفَق + المتوقَّع) > السقف، فلا تمرّ
# تشغيلتان متزامنتان قرب الحدّ معاً. الإنفاق الفعلي (رموز كل نداءات كلود بما فيها
# محاولات تصعيد الكاتب ودورات المراجع) يُصالِح الحجز بعد التشغيلة. غير مضبوط =>
# لا حدّ دولاري. عدّاد التفعيلات الذرّي يبقى الحارس المالي fail-closed المستقل.
SILK_PAID_DAILY_USD_CAP=
# التكلفة المتوقَّعة لتشغيلة /research (للبوابة المسبقة أعلاه) — الافتراضي 3.0$.
SILK_RESEARCH_EXPECTED_USD=

# تحديد المعدّل (M-1): أقصى عدد طلبات لكل هوية (X-API-Key أو IP) خلال النافذة؛
# التجاوز = 429. الافتراضي 120 طلباً/60 ثانية؛ 0 يعطّل الحدّ. تحديد بالذاكرة
# (أداة داخلية، بلا Redis). Simple in-memory rate limit (per key/IP).
# SILK_RATE_LIMIT=120
# SILK_RATE_WINDOW=60

# ملف عدّاد الاستهلاك (اختياري) — مستقل عن silk.db. Usage-counter DB path.
# SILK_USAGE_DB=data/usage.db

# القرص الدائم (Railway volume): متغير واحد يوجّه **كل** المخازن للقرص —
# قاعدة التحليلات silk.db + مخزن الحقائق silk_store.db + عدّاد usage.db +
# ذاكرة الطلبات cache/ — فتنجو كلها من إعادة النشر ولا يُدفع ثمن الجلب مرتين.
# One var points EVERY store at the persistent volume (survives redeploys).
# المتغيرات الصريحة أدناه تفوز عليه فرادى — explicit per-store vars win over it.
# SILK_DATA_DIR=/data

# مصيدة إقلاع (LESSONS.md البند ٤): اضبطها =1 على الإنتاج مع SILK_DATA_DIR —
# فترفض الخدمة الإقلاع بصوت عالٍ إن غاب توجيه تخزين دائم (SILK_DATA_DIR/SILK_DB)
# بدل الكتابة الصامتة على قرص فانٍ يُمحى عند إعادة النشر فتُفقَد التحليلات.
# مطفأة افتراضياً (وضع تطوير مفتوح). Fail-fast if no persistent store is routed.
# SILK_REQUIRE_PERSISTENT_DATA_DIR=1

# مسار قاعدة التحليلات (اختياري) — وجّهه لقرص دائم في الإنتاج (Railway volume
# على /data مثلًا؛ لا تركّب القرص فوق data/ لأنه يحوي ملفات CSV مرجعية).
# Analyses DB path override — point at a persistent disk in production
# (e.g. a Railway volume at /data; never mount over data/, it holds seed CSVs).
# SILK_DB=/data/silk.db

# مخزن الحقائق الموحّد (تدفقات تجارية/مؤشرات) — نفس القرص. Fact-store DB path.
# SILK_STORE_DB=/data/silk_store.db

# مجلد ذاكرة طلبات GET على القرص (silk_cache) — نفس القرص. Request-cache dir.
# SILK_CACHE_DIR=/data/cache

# ── التحديث الدوري · SCHEDULED REFRESH ────────────────────────────────────────
# ساعات بين تشغيلات تحديث المخزن (silk_collectors.refresh: مؤشرات البنك الدولي
# + تسخين مسبق لتدفقات Comtrade — رموز HS الأخيرة × أسواق الأولوية، بميزانية
# صلبة وbackoff). غير مضبوط/0 = معطّل. يعمل خيطاً داخل خدمة الويب (قرص Railway
# يُركَّب على خدمة واحدة — لا خدمة cron منفصلة).
# Hours between refresh runs; unset/0 = off. Runs in-process (volume is
# single-service on Railway).
# SILK_REFRESH_HOURS=24

# تأخير أول تشغيلة بعد الإقلاع بالثواني (افتراضي 120). Initial delay seconds.
# SILK_REFRESH_INITIAL_S=120

# احتياطي ميزانية Comtrade يُترك للطلبات الحية أثناء التسخين (افتراضي 150).
# Comtrade-budget reserve kept for live traffic during pre-warm.
# SILK_REFRESH_BUDGET_RESERVE=150

# أسواق الأولوية للتسخين المسبق (ISO3 بفواصل؛ الافتراضي أول 12 من قائمة المنصّة).
# Priority markets for pre-warming (comma ISO3; default: platform top 12).
# SILK_PRIORITY_MARKETS=ARE,KWT,QAT,OMN,BHR,EGY,JOR

# ── سياسة الحداثة · FRESHNESS / TTL POLICY ────────────────────────────────────
# نافذة الحداثة بالأيام لكل نوع: داخلها تُخدم القيمة من المخزن فوراً (مجاناً)؛
# خارجها تُخدم فوراً معلَّمة «stale» ويُطلَق تحديث بالخلفية (stale-while-
# revalidate). Freshness windows per data type (serve fast, refresh behind).
# SILK_FRESH_TRADE_DAYS=90
# SILK_FRESH_INDICATOR_DAYS=30
# SILK_FRESH_PRICE_DAYS=7

# تعطيل تحديث الخلفية عند العتاقة (للتشخيص فقط) — SWR kill switch.
# SILK_SWR=0

# مباعدة نداءات HTTP لكل مضيف (مللي ثانية) — النافذة العامة، وكومتريد له
# نافذة أوسع خاصة (بلاغ حي: 429 متكرر — حد كومتريد ~نداء/ثانية، والبعثات
# الاثنتا عشرة المتوازية تتشاركه). Per-host min gap; Comtrade gets its own.
# SILK_HTTP_MIN_GAP_MS=250
# SILK_COMTRADE_MIN_GAP_MS=1100
# SILK_HTTP_RETRIES=3

# تعطيل FAOSTAT صراحة (فجوة معلنة بلا أي محاولة جلب) — بلاغ حي: 401 متكرر؛
# بلا هذا العلم، أول 401/403 يفعّل قاطع دارة تلقائياً لبقية عمر العملية.
# Kill switch; without it, the first 401/403 auto-disables for the process.
# SILK_DISABLE_FAOSTAT=1

# مهلات نداءات كلود (ثوانٍ) — القياسية للبعثات، والموسّعة للمحلل الشامل
# وكاتب التقرير (مدخلاهما نتائج البعثات الاثنتي عشرة كاملة).
# SILK_AI_TIMEOUT_S=60
# SILK_AI_LONG_TIMEOUT_S=300

# CORS: أصول الواجهة المسموح لها بنداء الـ API (مفصولة بفواصل).
# الافتراضي الآن: نفس الأصل فقط (لا CORS) — الواجهة تُقدَّم من نفس الخدمة.
# للواجهة المنفصلة (Netlify) ضع دومينها؛ "*" يتطلب ضبطًا صريحًا ولا يُنصح به.
# CORS_ORIGINS=https://sage-pavlova-c221b1.netlify.app

# Google Trends (silk_trends_agent): لا مفتاح — يحتاج فقط: pip install pytrends
# Stage 2A: Trends وWITS وFAOSTAT ومرجع L1 مفعّلة دائماً بسياسة الخادم — لا تُدار
# بأعلام الواجهة. Always-on by server policy; UI flags no longer gate sources.

# Google Maps (silk_maps_agent): مجاني بحصة — مصانع/موزّعون/منافسون بالاسم وتقييماتهم.
# Free tier with quota. Real businesses + ratings by name (Places Text Search).
GOOGLE_MAPS_API_KEY=

# مكشطة خرائط قوقل (C1، silk_gmaps): عنوان **خدمة Railway ثانية** تشغّل
# gosom/google-maps-scraper (وضع خادم الويب + REST API) على الشبكة الخاصة —
# ليست حاوية بايثون هذه. اتركه فارغاً = تعطيل نظيف (لا كشط، لا أثر على /health
# أو المهام). راجع docs/DEPLOY_SCRAPER.md لخطوات النشر الدقيقة. مثال القيمة:
# http://gmaps-scraper.railway.internal:8080  (اسم مضيف داخلي خاص، لا عام).
# Second Railway service URL (private networking only, NEVER public). Empty =
# cleanly disabled. C2–C5 integration opens only after the owner confirms live.
SILK_GMAPS_SCRAPER_URL=

# Web Search (silk_websearch_agent): مجاني بحصة — Serper.dev افتراضيًا (SEARCH_PROVIDER).
# Free tier. Default provider Serper.dev (Google Search). Consumer/market signals.
# يُقبل أيضًا تحت الاسم SERPER_API_KEY (مرادف — SEARCH_API_KEY أعلى سلطة).
# Also accepted as SERPER_API_KEY (alias; SEARCH_API_KEY wins if both set).
SEARCH_API_KEY=

# أسعار السوق المحلي (silk_localprice_agent): مدفوع (SerpApi Google Shopping) —
# أسعار رفّ فعلية + مقارنة سعرك. طبقة /deepen فقط. PAID retail prices (deepen-only).
LOCALPRICE_API_KEY=

# Volza (silk_volza_agent): مدفوع — مستوردون بالاسم من بيانات بوالص الشحن.
# PAID subscription. Named importers/exporters from bills of lading.
VOLZA_API_KEY=

# explee (silk_explee_agent): مدفوع — مشترون وجهات اتصال B2B (امتثال GDPR/PDPL).
# PAID account (first ~333 lookups free). B2B buyers/contacts — legitimate outreach only.
EXPLEE_API_KEY=

# ── الذكاء الاصطناعي · OPTIONAL AI LAYER ──────────────────────────────────────
# الطبقة 3 (silk_ai_judge.py): كلود حَكَمًا ومُعِدّ تقرير فوق حقائق الوكلاء
# الموسومة فقط. P5: يعمل تلقائيًا على /analyze متى كان هذا المفتاح مضبوطًا
# **مع SILK_API_KEY** (بدون SILK_API_KEY يُحجب كل نداء كلود — حارس H2)؛
# بدونه تتدهور بأمان إلى لجنة التحكيم الحتمية. يُحتسب ضمن SILK_PAID_DAILY_CAP.
# Layer 3: Claude judge + report. P5: auto-on for /analyze when this key AND
# SILK_API_KEY are both set (H2 guard blocks it otherwise). Counted in the cap.
ANTHROPIC_API_KEY=
